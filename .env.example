# Supabase connection — copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing actual secrets.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Base URL for canonical/hreflang metadata. Set to production domain in prod.
SITE_URL=http://localhost:3000

# App URL used to build confirmation/unsubscribe links in emails.
# Falls back to SITE_URL or http://localhost:3000 if not set.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (email service) — required for price alert confirmation emails.
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# "From" address for alert emails. Falls back to onboarding@resend.dev
# (Resend sandbox) until timicy.com is DNS-verified.
ALERTS_FROM_EMAIL=alerts@timicy.com
